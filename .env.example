# ── Copie ce fichier en .env et remplis les valeurs ──────────────────────────
# Ne commite JAMAIS .env sur GitHub !

# Firebase — https://console.firebase.google.com → Paramètres → Vos applications
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudflare Worker — URL de ton worker déployé
# Exemple : https://studyai-worker.ton-sous-domaine.workers.dev
VITE_WORKER_URL=
